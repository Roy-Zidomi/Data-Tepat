
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://data-tepat.vercel.app
ALLOWED_ORIGINS=https://data-tepat.vercel.app

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Cookies for cross-domain frontend/backend
COOKIE_SAMESITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
