# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bantutepat
DIRECT_URL=postgresql://postgres:password@localhost:5432/bantutepat

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Cookies
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=-
